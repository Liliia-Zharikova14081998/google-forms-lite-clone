{
  "name": "google-forms-clone",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "client": "npm run dev -w packages/client",
    "server": "npm run dev -w packages/server",
    "install-all": "npm install && npm install -w packages/client && npm install -w packages/server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
